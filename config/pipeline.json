{
  "duration_minutes": 12,
  "duration_minutes_max": 15,
  "continue_keyword": "Next",
  "words_per_minute": 145,
  "max_scenes": 50,
  "min_scenes": 12,
  "words_per_scene": 35,
  "min_words_per_scene": 12,
  "generate_thumbnail": true,
  "ingest_style_channels": true,
  "ingest_youtube_style_sources": false,
  "max_style_sources": 12,
  "style_source_wait_timeout": 1200,
  "source_request_timeout": 180,
  "source_reconcile_timeout": 90,
  "source_wait_timeout": 900,
  "source_add_delay_sec": 5,
  "pre_chat_delay_sec": 15,
  "clip_pad_start_sec": 0.0,
  "clip_pad_end_sec": 0.3,
  "max_clip_source_sec": 8.0,
  "tts_provider": "azure",
  "tts_modulation": true,
  "tts_humanize": true,
  "tts_merge_chunks": true,
  "tts_chunk_pause_ms": 120,
  "tts_azure_style_degree": 0.92,
  "tts_voices": ["en-US-ChristopherNeural"],
  "tts_voice_pool": {
    "narrator": "en-US-ChristopherNeural",
    "narrator_alt": "en-US-ChristopherNeural",
    "quote_male": "en-US-GuyNeural",
    "quote_female": "en-US-AriaNeural",
    "authority": "en-US-GuyNeural",
    "witness": "en-US-JennyNeural"
  },
  "tts_rate": "-4%",
  "letterbox_color": "0x000000",
  "captions": {
    "burn_into_video": false,
    "upload_youtube_srt": true,
    "generate_word_timings": false
  },
  "vps_movies_dir": "/opt/movies",
  "bg_music": {
    "enabled": true,
    "track": "config/bg_music/ambient_cinematic.mp3",
    "volume": 0.12,
    "fade_in_sec": 2.0,
    "fade_out_sec": 3.0,
    "scene_dynamic_volume": true,
    "scene_crossfade_sec": 0.5,
    "duck_under_voice": true,
    "duck_amount": 0.65
  },
  "end_card": {
    "enabled": true,
    "image": "config/end_card/subscribe.png",
    "script": "If you want more classic films broken down the same way, subscribe to Retro Movie Archive. Thanks for watching.",
    "voice": "en-US-ChristopherNeural"
  }
}
